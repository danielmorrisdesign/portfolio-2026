---
interface Slide {
  label?: string;
  caption?: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<div class="cs-carousel">
  <div class="cs-carousel__viewport">
    <div class="cs-carousel__track">
      {slides.map((slide, i) => (
        <div class="cs-carousel__slide" data-caption={slide.caption ?? ''}>
          <div class="img-ph img-ph--16x9">
            <span class="img-ph__label">{slide.label ?? `Screen ${i + 1}`}</span>
          </div>
        </div>
      ))}
    </div>
    <button class="cs-carousel__btn cs-carousel__prev" aria-label="Previous slide">←</button>
    <button class="cs-carousel__btn cs-carousel__next" aria-label="Next slide">→</button>
  </div>
  <div class="cs-carousel__footer">
    <span class="cs-carousel__caption">{slides[0]?.caption ?? ''}</span>
    <div class="cs-carousel__dots">
      {slides.map((_, i) => (
        <button
          class:list={['cs-carousel__dot', { 'is-active': i === 0 }]}
          aria-label={`Go to slide ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.cs-carousel').forEach((carousel) => {
    const track = carousel.querySelector('.cs-carousel__track') as HTMLElement;
    const slides = Array.from(carousel.querySelectorAll('.cs-carousel__slide')) as HTMLElement[];
    const caption = carousel.querySelector('.cs-carousel__caption') as HTMLElement;
    const prevBtn = carousel.querySelector('.cs-carousel__prev');
    const nextBtn = carousel.querySelector('.cs-carousel__next');
    const dots = Array.from(carousel.querySelectorAll('.cs-carousel__dot'));
    let current = 0;

    function goTo(idx: number) {
      current = Math.max(0, Math.min(idx, slides.length - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      if (caption) caption.textContent = slides[current].dataset.caption ?? '';
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  });
</script>
