---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Lightbox from '../../components/Lightbox.astro';
import { cases } from '../../data/cases.js';
import '../../styles/case.css';
import '../../styles/case-study.css';

const item = cases.find(c => c.slug === 'kite');
---

<Layout title={`${item.title} | Daniel Morris`} description={item.shortDesc}>
  <div class="shell">
    <main class="main">

      <Nav />

      <!-- Title + tagline + meta -->
      <header class="case-header fadein delay-2">
        <h1 class="case-title">
          <span class="accent">›</span> {item.title}<span class="cursor"></span>
        </h1>
        <p class="cs-tagline">{item.tagline}</p>
        <div class="cs-meta-strip">
          <div class="cs-meta-item">
            <span class="cs-meta-label">role</span>
            <span class="cs-meta-value">{item.role}</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">timeline</span>
            <span class="cs-meta-value">{item.timeline}</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">platform</span>
            <span class="cs-meta-value">{item.platform}</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">product</span>
            <a class="cs-meta-value cs-meta-link" href={item.liveUrl} target="_blank" rel="noopener noreferrer">Visit site ↗</a>
          </div>
        </div>
        <div class="tags">
          {item.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <!-- Intro narrative -->
      <section class="cs-section">
        <p class="cs-intro-lead">{item.intro[0]}</p>
        <div class="cs-prose">
          {item.intro.slice(1).map(para => <p class="cs-text">{para}</p>)}
        </div>
      </section>

      <!-- Hero image -->
      <div class="cs-hero">
        <img src="/images/kite/hero.jpg" alt="Conversation interface + live store preview" class="cs-hero__img" loading="lazy" />
      </div>

      <!-- My role -->
      <section class="cs-section">
        <p class="cs-label">// my role</p>
        <div class="cs-prose">
          {item.role_detail.map(para => <p class="cs-text">{para}</p>)}
        </div>
        {item.responsibilities && (
          <div class="cs-responsibilities">
            {item.responsibilities.map(r => <span class="cs-responsibility">{r}</span>)}
          </div>
        )}
      </section>

      <!-- Finding the right problem -->
      <section class="cs-section">
        <p class="cs-label">// finding the right problem</p>
        <p class="cs-text" style="margin-bottom: 28px;">The brief was open-ended: build something AI-first that could become Appsmith's next flagship. We didn't know what that was or who it was for. Each pivot below was a real commitment — research, prototypes, user tests — before we had the signal to move on.</p>

        <!-- Phase overview -->
        <div class="cs-phase-nav">
          {item.pivots.map((pivot, i) => (
            <div class={`cs-phase-nav__item${pivot.status ? ` cs-phase-nav__item--${pivot.status}` : ''}${i === item.pivots.length - 1 ? ' cs-phase-nav__item--last' : ''}${i === 1 ? ' cs-phase-nav__item--pre-tangent' : ''}`}>
              <span class="cs-phase-nav__num">// {pivot.index}</span>
              <span class="cs-phase-nav__label">{pivot.heading}</span>
              {pivot.status === 'scrapped' && <span class="cs-phase-nav__tag">scrapped</span>}
            </div>
          ))}
        </div>

        <!-- The pivots -->
        <div class="cs-bets">
          {item.pivots.map(pivot => (
            <div class="cs-bet">
              <span class="cs-bet__label">// {pivot.index}</span>
              <h2 class="cs-bet__heading">{pivot.heading}</h2>
              {pivot.takeaway && <p class="cs-pivot-takeaway">{pivot.takeaway}</p>}
              {pivot.framing && <p class="cs-pivot-framing">{pivot.framing}</p>}
              <div class="cs-bet__body">
                {pivot.body.map((para, i) => (
                  <>
                    <p class="cs-text">{para}</p>
                    {pivot.screenshots && (() => {
                      const atIndex = pivot.screenshots.filter(s => s.after === i);
                      if (atIndex.length === 0) return null;
                      if (atIndex.length === 1) return (
                        <div class="cs-screen-full">
                          <img src={atIndex[0].src} alt={atIndex[0].label} class="cs-hero__img" />
                          <p class="cs-caption">{atIndex[0].label}</p>
                        </div>
                      );
                      return (
                        <div class="cs-pivot-screens">
                          {atIndex.map(s => (
                            <figure class="cs-pivot-screen">
                              <img src={s.src} alt={s.label} />
                              <figcaption class="cs-caption">{s.label}</figcaption>
                            </figure>
                          ))}
                        </div>
                      );
                    })()}
                    {pivot.callout && pivot.calloutAfter === i && (
                      <blockquote class="cs-callout">{pivot.callout}</blockquote>
                    )}
                    {pivot.pipeline && i === 1 && (
                      <div class="cs-pipeline">
                        {pivot.pipeline.map((node, j) => (
                          <>
                            <div class={`cs-pipeline__node${node.anchor ? ' cs-pipeline__node--anchor' : ''}`}>
                              <span class="cs-pipeline__num">0{j + 1}</span>
                              <span class="cs-pipeline__label">{node.label}</span>
                              <span class="cs-pipeline__desc">{node.desc}</span>
                            </div>
                            {j < pivot.pipeline.length - 1 && (
                              <span class="cs-pipeline__arrow">→</span>
                            )}
                          </>
                        ))}
                      </div>
                    )}
                  </>
                ))}
              </div>
              {pivot.callout && pivot.calloutAfter === undefined && (
                <blockquote class="cs-callout">{pivot.callout}</blockquote>
              )}
              {pivot.stats && (
                <div class="cs-insights">
                  {pivot.stats.map(stat => (
                    <div class="cs-insight">
                      <span class="cs-insight__value">{stat.value}</span>
                      <span class="cs-insight__label">{stat.label}</span>
                      <span class="cs-insight__note">{stat.note}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>


      <!-- Key decisions -->
      <section class="cs-section">
        <p class="cs-label">// key decisions</p>
        <div class="cs-decisions">
          {item.keyDecisions.map(decision => (
            <div class="cs-decision">
              <h2 class="cs-decision__heading">{decision.heading}</h2>
              <p class="cs-text">{decision.body}</p>
              {decision.screenshots && decision.screenshots.length > 0 ? (
                <div class={`cs-decision-screens cs-decision-screens--${decision.screenshots.length}`}>
                  {decision.screenshots.map(s => (
                    <figure class="cs-decision-screen">
                      <img src={s.src} alt={s.label} />
                      <figcaption class="cs-caption">{s.label}</figcaption>
                    </figure>
                  ))}
                </div>
              ) : (
                <div class="img-ph img-ph--16x9">
                  <span class="img-ph__label">{decision.screenshotLabel}</span>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Outcomes -->
      <section class="cs-section">
        <p class="cs-label">// outcomes</p>
        <div class="cs-outcomes">
          {item.outcomes.map(outcome => (
            <div class="cs-outcome">
              <span class="cs-outcome__value">{outcome.value}</span>
              <span class="cs-outcome__label">{outcome.label}</span>
            </div>
          ))}
        </div>
        <p class="cs-outcomes-note">{item.outcomes_note}</p>
        {item.nda && (
          <p class="cs-nda">Note: final design files and prototypes are covered under NDA.</p>
        )}
      </section>

      <!-- Reflection -->
      <section class="cs-section">
        <p class="cs-label">// reflection</p>
        <div class="cs-prose">
          {item.reflection.map(para => <p class="cs-reflection">{para}</p>)}
        </div>
      </section>

    </main>
  </div>
  <Lightbox />
</Layout>
