---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Carousel from '../../components/Carousel.astro';
import Lightbox from '../../components/Lightbox.astro';
import { cases } from '../../data/cases.js';
import '../../styles/case.css';
import '../../styles/case-study.css';

const item = cases.find(c => c.slug === 'kite');
---

<Layout title={`${item.title} | Daniel Morris`} description={item.shortDesc}>
  <div class="shell">
    <main class="main">

      <Nav />

      <!-- Title + tagline + meta -->
      <header class="case-header fadein delay-2">
        <h1 class="case-title">
          <span class="accent">›</span> {item.title}<span class="cursor"></span>
        </h1>
        <p class="cs-tagline">{item.tagline}</p>
        <div class="cs-meta-strip">
          <div class="cs-meta-item">
            <span class="cs-meta-label">role</span>
            <span class="cs-meta-value">{item.role}</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">timeline</span>
            <span class="cs-meta-value">{item.timeline}</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">platform</span>
            <span class="cs-meta-value">{item.platform}</span>
          </div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">product</span>
            <a class="cs-meta-value cs-meta-link" href={item.liveUrl} target="_blank" rel="noopener noreferrer">Visit site ↗</a>
          </div>
        </div>
        <div class="tags">
          {item.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <!-- Intro narrative -->
      <section class="cs-section">
        <p class="cs-intro-lead">{item.intro[0]}</p>
        <div class="cs-prose">
          {item.intro.slice(1).map(para => <p class="cs-text">{para}</p>)}
        </div>
      </section>

      <!-- Hero image -->
      <div class="cs-hero">
        <img src="/images/kite/hero.jpg" alt="Conversation interface + live store preview" class="cs-hero__img" loading="lazy" />
      </div>

      <!-- My role -->
      <section class="cs-section">
        <p class="cs-label">// my role</p>
        <div class="cs-prose">
          {item.role_detail.map(para => <p class="cs-text">{para}</p>)}
        </div>
        {item.responsibilities && (
          <div class="cs-responsibilities">
            {item.responsibilities.map(r => <span class="cs-responsibility">{r}</span>)}
          </div>
        )}
      </section>

      <!-- Approach -->
      <section class="cs-section">
        <p class="cs-label">// how I worked through it</p>
        <div class="cs-prose">
          {item.approach.map(para => <p class="cs-text">{para}</p>)}
        </div>
      </section>

      <!-- Key decisions -->
      <section class="cs-section">
        <p class="cs-label">// key decisions</p>
        <div class="cs-decisions">
          {item.keyDecisions.map(decision => (
            <div class="cs-decision">
              <h2 class="cs-decision__heading">{decision.heading}</h2>
              <p class="cs-text">{decision.body}</p>
              {decision.screenshots && decision.screenshots.length > 0 && (
                <div class={`cs-decision-screens cs-decision-screens--${decision.screenshots.length}`}>
                  {decision.screenshots.map(s => (
                    <figure class="cs-decision-screen">
                      <img src={s.src} alt={s.label} />
                      <figcaption class="cs-caption">{s.label}</figcaption>
                    </figure>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Outcomes -->
      <section class="cs-section">
        <p class="cs-label">// outcomes</p>
        <div class="cs-outcomes">
          {item.outcomes.map(outcome => (
            <div class="cs-outcome">
              <span class="cs-outcome__value">{outcome.value}</span>
              <span class="cs-outcome__label">{outcome.label}</span>
            </div>
          ))}
        </div>
        <p class="cs-outcomes-note">{item.outcomes_note}</p>
        {item.nda && (
          <p class="cs-nda">{typeof item.nda === 'string' ? item.nda : 'Note: final design files and prototypes are covered under NDA.'}</p>
        )}
      </section>

      <!-- Final product -->
      <section class="cs-section">
        <p class="cs-label">// final product</p>
        <Carousel slides={item.screenshots} />
      </section>

      <!-- Reflection -->
      <section class="cs-section">
        <p class="cs-label">// reflection</p>
        <div class="cs-prose">
          {item.reflection.map(para => <p class="cs-reflection">{para}</p>)}
        </div>
      </section>

    </main>
  </div>
  <Lightbox />
</Layout>
